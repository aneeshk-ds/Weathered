{
  "name": "weathered",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace apps/mobile start",
    "dev:mobile:device": "npm --workspace apps/mobile run start:device",
    "dev:mobile:device:auto": "node scripts/start-mobile-device.mjs",
    "dev:device:stack": "node scripts/start-device-stack.mjs",
    "dev:api": "npm --workspace apps/api run dev",
    "export:web": "npm --workspace apps/mobile run export:web",
    "typecheck": "npm --workspace packages/shared run build && npm --workspace apps/api run build && npm --workspace apps/mobile run typecheck",
    "dev:mobile:tunnel": "npm --workspace apps/mobile run start -- --tunnel --port 8081"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3"
  }
}

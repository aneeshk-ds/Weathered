{
  "name": "@weathered/mobile",
  "version": "2.1.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:device": "expo start --lan --port 8081",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web --output-dir ../../dist-web",
    "typecheck": "tsc --noEmit",
    "build:android:apk": "npx eas-cli build --platform android --profile preview-apk"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.2",
    "@weathered/shared": "2.0.1",
    "expo": "~55.0.24",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.22",
    "expo-location": "~19.0.7",
    "expo-sharing": "~55.0.20",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "typescript": "~5.9.2"
  }
}
